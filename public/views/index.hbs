<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Oxygen Blog - Modern Blog Platform</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="/static/style.css" rel="stylesheet">
</head>
<body>

{{> partial/_navbar }}

<!-- Main Content -->
<main class="container my-5 pt-5">
    <!-- Hero Section -->
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 fw-bold text-primary mb-3">
                <i class="bi bi-journal-text me-3"></i>
                Welcome to Oxygen Blog
            </h1>
            <p class="lead text-muted">
                Discover amazing stories, share your thoughts, and connect with our community
            </p>
        </div>
    </div>

    <!-- Posts Grid -->
    <div class="row" id="postsContainer">
        <!-- Post 1 -->
        <div class="col-lg-6 col-md-12 mb-4">
            <div class="card h-100 shadow-sm post-card">
                <div class="card-img-top bg-primary text-white p-4 text-center">
                    <i class="bi bi-image display-1"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-primary">Technology</span>
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>
                            Dec 15, 2024
                        </small>
                    </div>
                    <h5 class="card-title">Getting Started with Go Web Development</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Learn the fundamentals of building web applications with Go. 
                        This comprehensive guide covers everything from basic concepts to advanced patterns.
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <div class="d-flex align-items-center">
                            <img src="https://via.placeholder.com/32x32" class="rounded-circle me-2" alt="Author">
                            <small class="text-muted">John Doe</small>
                        </div>
                        <a href="/post/1" class="btn btn-outline-primary btn-sm">
                            Read More <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Post 2 -->
        <div class="col-lg-6 col-md-12 mb-4">
            <div class="card h-100 shadow-sm post-card">
                <div class="card-img-top bg-success text-white p-4 text-center">
                    <i class="bi bi-code-slash display-1"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-success">Programming</span>
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>
                            Dec 14, 2024
                        </small>
                    </div>
                    <h5 class="card-title">Building RESTful APIs with Go</h5>
                    <p class="card-text text-muted flex-grow-1">
                        A deep dive into creating robust and scalable REST APIs using Go. 
                        Best practices, error handling, and testing strategies included.
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <div class="d-flex align-items-center">
                            <img src="https://via.placeholder.com/32x32" class="rounded-circle me-2" alt="Author">
                            <small class="text-muted">Jane Smith</small>
                        </div>
                        <a href="/post/2" class="btn btn-outline-success btn-sm">
                            Read More <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Post 3 -->
        <div class="col-lg-6 col-md-12 mb-4">
            <div class="card h-100 shadow-sm post-card">
                <div class="card-img-top bg-warning text-white p-4 text-center">
                    <i class="bi bi-database display-1"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-warning">Database</span>
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>
                            Dec 13, 2024
                        </small>
                    </div>
                    <h5 class="card-title">Database Design Patterns</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Explore common database design patterns and how to implement them effectively 
                        in your applications for better performance and maintainability.
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <div class="d-flex align-items-center">
                            <img src="https://via.placeholder.com/32x32" class="rounded-circle me-2" alt="Author">
                            <small class="text-muted">Mike Johnson</small>
                        </div>
                        <a href="/post/3" class="btn btn-outline-warning btn-sm">
                            Read More <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Post 4 -->
        <div class="col-lg-6 col-md-12 mb-4">
            <div class="card h-100 shadow-sm post-card">
                <div class="card-img-top bg-info text-white p-4 text-center">
                    <i class="bi bi-cloud display-1"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-info">Cloud</span>
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>
                            Dec 12, 2024
                        </small>
                    </div>
                    <h5 class="card-title">Deploying Go Applications to the Cloud</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Step-by-step guide to deploying your Go applications to various cloud platforms. 
                        Learn about containers, orchestration, and monitoring.
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <div class="d-flex align-items-center">
                            <img src="https://via.placeholder.com/32x32" class="rounded-circle me-2" alt="Author">
                            <small class="text-muted">Sarah Wilson</small>
                        </div>
                        <a href="/post/4" class="btn btn-outline-info btn-sm">
                            Read More <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Post 5 -->
        <div class="col-lg-6 col-md-12 mb-4">
            <div class="card h-100 shadow-sm post-card">
                <div class="card-img-top bg-danger text-white p-4 text-center">
                    <i class="bi bi-shield-check display-1"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-danger">Security</span>
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>
                            Dec 11, 2024
                        </small>
                    </div>
                    <h5 class="card-title">Web Application Security Best Practices</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Essential security practices every web developer should know. 
                        Protect your applications from common vulnerabilities and attacks.
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <div class="d-flex align-items-center">
                            <img src="https://via.placeholder.com/32x32" class="rounded-circle me-2" alt="Author">
                            <small class="text-muted">Alex Brown</small>
                        </div>
                        <a href="/post/5" class="btn btn-outline-danger btn-sm">
                            Read More <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Post 6 -->
        <div class="col-lg-6 col-md-12 mb-4">
            <div class="card h-100 shadow-sm post-card">
                <div class="card-img-top bg-secondary text-white p-4 text-center">
                    <i class="bi bi-graph-up display-1"></i>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-secondary">Performance</span>
                        <small class="text-muted">
                            <i class="bi bi-calendar3 me-1"></i>
                            Dec 10, 2024
                        </small>
                    </div>
                    <h5 class="card-title">Optimizing Go Application Performance</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Learn advanced techniques to optimize your Go applications for maximum performance. 
                        Profiling, benchmarking, and optimization strategies covered.
                    </p>
                    <div class="d-flex justify-content-between align-items-center mt-auto">
                        <div class="d-flex align-items-center">
                            <img src="https://via.placeholder.com/32x32" class="rounded-circle me-2" alt="Author">
                            <small class="text-muted">Tom Davis</small>
                        </div>
                        <a href="/post/6" class="btn btn-outline-secondary btn-sm">
                            Read More <i class="bi bi-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Pagination -->
    <div class="row mt-5 pb-5">
        <div class="col-12 d-flex justify-content-center">
            <nav aria-label="Posts pagination">
                <ul class="pagination">
                    <li class="page-item disabled">
                        <a class="page-link" href="#" tabindex="-1" aria-disabled="true">
                            <i class="bi bi-chevron-left"></i> Previous
                        </a>
                    </li>
                    <li class="page-item active" aria-current="page">
                        <a class="page-link" href="#">1</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="#">2</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="#">3</a>
                    </li>
                    <li class="page-item">
                        <a class="page-link" href="#">
                            Next <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</main>

{{> partial/_footer }}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"></script>
</body>
</html>